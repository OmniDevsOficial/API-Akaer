generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  VISUALIZADOR
}

model User {
  id         Int      @id @default(autoincrement())
  nome       String   @db.VarChar(100)
  email      String   @unique @db.VarChar(225)
  password   String   @db.VarChar(255)
  role       Role     @default(VISUALIZADOR)
  ativo      Boolean  @default(true)
  criado_em  DateTime @default(now())

  @@map("users")
}

model Norma {
  codigo          String       @id @db.VarChar(50)
  titulo          String       @db.VarChar(255)
  orgao_emissor   String       @db.VarChar(25)
  categoria       String       @db.VarChar(100)
  etapa_projeto   String?      @db.VarChar(100)
  revisao         String?      @db.VarChar(20)
  status          norma_status @default(Ativa)
  data_publicacao DateTime     @db.Date
  arquivo         String       @db.VarChar(500)

  @@map("norma")
}

enum norma_status {
  Ativa
  Obsoleta
}